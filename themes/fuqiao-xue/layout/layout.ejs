<!doctype html>
<%
const canonicalBase = (config.url || '').replace(/\/$/, '');
const canonicalPath = (`/${page.path || ''}`)
  .replace(/\/index\.html$/, '/')
  .replace(/\.html$/, '.html');
const canonicalUrl = `${canonicalBase}${canonicalPath}`;
%>
<html lang="<%= page.lang || config.language || 'en' %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="dark">
    <title><% if (page.title) { %><%= page.title %> · <% } %><%= config.title %></title>
    <meta name="description" content="<%= page.summary || config.description %>">
    <link rel="canonical" href="<%= canonicalUrl %>">
    <!-- Open Graph -->
    <meta property="og:title" content="<%= page.title || config.title %>">
    <meta property="og:description" content="<%= page.summary || config.description %>">
    <meta property="og:url" content="<%= canonicalUrl %>">
    <meta property="og:type" content="<%= page.layout === 'post' ? 'article' : 'website' %>">
    <meta property="og:site_name" content="<%= config.title %>">
    <meta property="og:locale" content="<%-
      (page.lang || config.language || 'en') === 'zh-Hans' ? 'zh_CN' : (page.lang || config.language || 'en')
    %>">
    <%_ if (page.layout === 'post') { _%>
    <meta property="article:published_time" content="<%= page.date.toISOString() %>">
    <%_ if (page.updated) { _%>
    <meta property="article:modified_time" content="<%= page.updated.toISOString() %>">
    <%_ } _%>
    <%_ page.tags.each(tag => { _%>
    <meta property="article:tag" content="<%= tag.name %>">
    <%_ }) _%>
    <%_ } _%>
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= page.title || config.title %>">
    <meta name="twitter:description" content="<%= page.summary || config.description %>">
    <!-- hreflang -->
    <%
    const pageLang = page.lang || config.language || 'en';
    const isZh = page.path.startsWith('zh-Hans/');
    const altLang = isZh ? 'en' : 'zh-Hans';
    const altPath = isZh ? page.path.replace(/^zh-Hans\//, '') : 'zh-Hans/' + page.path;
    const altUrl = canonicalBase + '/' + altPath.replace(/index\.html$/, '').replace(/\.html$/, '');
    %>
    <link rel="alternate" hreflang="<%= pageLang %>" href="<%= canonicalUrl %>">
    <%_ if (page.path === 'index.html' || page.path === 'zh-Hans/index.html') { _%>
    <link rel="alternate" hreflang="<%= altLang %>" href="<%= altUrl %>">
    <%_ } _%>
    <link rel="alternate" hreflang="x-default" href="<%= isZh ? altUrl : canonicalUrl %>">
    <%- partial('partial/json-ld', { canonicalUrl }) %>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="shortcut icon" href="/favicon.ico">
    <%- css('css/style') %>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <%- partial('partial/header') %>
    <main id="main" class="site-main" tabindex="-1">
      <%- body %>
    </main>
    <%- partial('partial/footer') %>
  </body>
</html>
