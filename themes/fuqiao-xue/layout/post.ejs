<article class="section prose">
  <header class="page-header">
    <p class="eyebrow"><%= date(page.date, 'YYYY-MM-DD') %><% if (page.lang) { %> · <%= page.lang %><% } %></p>
    <h1><%= page.title %></h1>
    <% if (page.summary) { %><p><%= page.summary %></p><% } %>
    <% if (page.tags && page.tags.length) { %>
      <ul class="tag-list" role="list" aria-label="Tags">
        <% page.tags.each(function(tag) { %>
          <li><span><%= tag.name %></span></li>
        <% }) %>
      </ul>
    <% } %>
  </header>
  <div class="prose__body">
    <%- page.content %>
  </div>
</article>
